# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# --- Spotify OAuth ---
# Normal setup uses PKCE, so a Client Secret is not required.
# Create a Spotify app and paste its Client ID in Settings or here. PKCE does
# not need a Client Secret, though Octave still accepts one for legacy setups.
# Add the callback URI shown in Settings to the app's redirect URI list.
OCTAVE_BUNDLED_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# --- Jellyfin ---
JELLYFIN_URL=
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# --- Lidarr ---
LIDARR_URL=
LIDARR_API_KEY=

# --- Web server / scheduling ---
SYNC_MODE=web              # web | oneshot
SYNC_ON_STARTUP=false      # run a sync as soon as the container starts
SYNC_SCHEDULE=0 2 * * *    # cron expression (UTC by default); set to empty string to disable
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
TZ=UTC                     # eg Australia/Sydney — also controls cron timezone
WEB_PORT=8000

# --- ListenBrainz (optional) ---
# MusicBrainz ID resolution, popularity data, collaborative filtering recs.
# Get your token from https://listenbrainz.org/profile/
# LISTENBRAINZ_TOKEN=

# --- Last.fm (optional) ---
# Playcounts, similar artist/track discovery, scrobble history.
# Get your API key from https://www.last.fm/api/account/create
# LASTFM_API_KEY=
# LASTFM_USERNAME=

# --- Web security (optional) ---
# Leave AUTH_PASSWORD empty for LAN-trust mode. Set it before exposing Octave.
AUTH_USERNAME=octave
AUTH_PASSWORD=
