# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# --- Spotify OAuth app (https://developer.spotify.com/dashboard) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the redirect URI registered on the Spotify app. For Docker on the
# same machine as your browser, the default is fine.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Jellyfin ---
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# --- Lidarr ---
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=

# --- Web server / scheduling ---
SYNC_MODE=web              # web | oneshot
SYNC_ON_STARTUP=false      # run a sync as soon as the container starts
SYNC_SCHEDULE=0 2 * * *    # cron expression (UTC by default); set to empty string to disable
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
TZ=UTC                     # eg Australia/Sydney — also controls cron timezone
WEB_PORT=8000

# --- ListenBrainz (optional) ---
# MusicBrainz ID resolution, popularity data, collaborative filtering recs.
# Get your token from https://listenbrainz.org/profile/
# LISTENBRAINZ_TOKEN=

# --- Last.fm (optional) ---
# Playcounts, similar artist/track discovery, scrobble history.
# Get your API key from https://www.last.fm/api/account/create
# LASTFM_API_KEY=

# --- API security (optional) ---
# Leave empty to disable auth on the local API. Set a long random string to
# require X-API-Key on every request to /api/*.
API_KEY=
